# ── KIS API ──
# KIS_MODE=mock 시 KIS_APP_KEY / KIS_APP_SECRET / KIS_ACCOUNT_NO 없어도 동작
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_MODE=mock           # mock | paper | live  ← 실전 전환 시 절대 실수 금지

# ── LLM ──
ANTHROPIC_API_KEY=

# ── DB (Railway PostgreSQL) ──
DATABASE_URL=postgresql://user:password@host:5432/railway

# ── 데이터 API ──
DART_API_KEY=
FRED_API_KEY=
NEWS_API_KEY=           # Serper (선택)

# ── MCP 서버 URL (로컬 개발 / Railway internal) ──
MCP_KIS_URL=http://localhost:3001/mcp
MCP_DART_URL=http://localhost:3002/mcp
MCP_PORTFOLIO_URL=http://localhost:3003/mcp
MCP_NEWS_URL=http://localhost:3004/mcp

# ── 암호화 (API 키 DB 저장용) ──
ENCRYPTION_SECRET=

# ── 앱 ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
